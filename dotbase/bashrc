#!/bin/env bash

DOTFILES=${HOME}/dotfiles
BASHRC_COMMON="${DOTFILES}/dotbase/bashrc_common"
BASHRC_INTERACTIVE="${DOTFILES}/dotbase/bashrc_interactive"

# Always load common env/path for both interactive and non-interactive shells.
[ -f "${BASHRC_COMMON}" ] && source "${BASHRC_COMMON}"

# Stop here for non-interactive shells.
[[ $- != *i* ]] && return

# Interactive-only setup.
[ -f "${BASHRC_INTERACTIVE}" ] && source "${BASHRC_INTERACTIVE}"
